{
  "name": "Modded cube combination",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "SharedModules": {
        "$path": "src/sharedModules"
      },
      "CubeModels": {
        "$className": "Folder"
      }
    },

    "ServerStorage": {
      "Modules": {
        "$path": "src/serverModules"
      }
    },

    "ServerScriptService": {
