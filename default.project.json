          "$path": "src/starterPlayer"
        }
      },
      "StarterCharacterScripts": {
        "Client": {
          "$path": "src/starterCharacter"
        }
      }
    },

    "Workspace": {
      "Cubes": {
        "$className": "Folder"
      }
    }
  }
}